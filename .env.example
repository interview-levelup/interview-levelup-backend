# ── Go Backend ──────────────────────────────
PORT=8080
JWT_SECRET=change-me-to-a-long-random-string

# ── PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=interview
DB_PASSWORD=interview_pass
DB_NAME=interview_db
DB_SSLMODE=disable

# ── Python Agent ────────────────────────────
AGENT_BASE_URL=http://agent:8000

# ── LLM (forwarded to the agent container) ──
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
