# ── Go Backend ──────────────────────────────
PORT=8080
JWT_SECRET=change-me-to-a-long-random-string

# ── PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=interview
DB_PASSWORD=interview_pass
DB_NAME=interview_db
DB_SSLMODE=disable

# ── Python Agent ────────────────────────────
AGENT_BASE_URL=http://agent:8000

# ── LLM (forwarded to the agent container) ──
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# ── Whisper STT (called directly by Go backend) ──
# WHISPER_API_KEY defaults to LLM_API_KEY if not set
WHISPER_API_KEY=
# WHISPER_BASE_URL: leave empty for OpenAI default; set for self-hosted Whisper
WHISPER_BASE_URL=
